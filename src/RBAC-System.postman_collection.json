        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                "if (pm.response.code !== 200) return;",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('accessToken',  body.accessToken);",
                "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                "try {",
                "    const p = JSON.parse(atob(body.accessToken.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));",
                "    if (p.sub) pm.collectionVariables.set('userId', p.sub);",
                "    pm.test('New token version tv: ' + p.tv, () => pm.expect(p.tv).to.not.be.undefined);",
                "} catch(e) {}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh"] }
          }
        },

        {
          "name": "Login — Wrong Password (expect 401)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Wrong password → 401', () => pm.expect(pm.response.code).to.equal(401));",
                "pm.test('Code is INVALID_CREDENTIALS', () => pm.expect(pm.response.json().code).to.equal('INVALID_CREDENTIALS'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] }
          }
        },

        {
          "name": "Corrupt JWT (expect 401)",
          "description": "GlobalExceptionMiddleware catches SecurityTokenException and returns 401. Raw token is never echoed — only its SHA-256 hash is logged server-side.",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Corrupt JWT → 401', () => pm.expect(pm.response.code).to.equal(401));",
                "pm.test('Response body does not echo raw token', () => pm.expect(pm.response.text()).to.not.include('eyJ'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer thisis.not.a.valid.jwt.atall" }],
            "url": { "raw": "{{baseUrl}}/api/v1/tenants/{{tenantId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","tenants","{{tenantId}}"] }
          }
        }

      ]
