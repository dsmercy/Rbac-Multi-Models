  "item": [

    {
      "name": "1. Authentication",
      "item": [

        {
          "name": "Login (admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.expect(pm.response.code).to.equal(200));",
                "if (pm.response.code !== 200) return;",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('accessToken',  body.accessToken);",
                "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                "try {",
                "    const p = JSON.parse(atob(body.accessToken.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));",
                "    if (p.sub) pm.collectionVariables.set('userId', p.sub);",
                "    pm.test('userId extracted: ' + p.sub, () => pm.expect(p.sub).to.be.a('string'));",
                "    pm.test('tid claim matches tenantId', () => pm.expect(p.tid).to.equal(pm.collectionVariables.get('tenantId')));",
                "    pm.test('tv (token version) is number', () => pm.expect(typeof p.tv).to.not.equal('undefined'));",
                "    console.log('sub (userId):', p.sub, '| tv:', p.tv, '| is_super_admin:', p.is_super_admin);",
                "} catch(e) { console.error('JWT decode error:', e); }"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] }
          }
        },

        {
          "name": "Login (viewer) — saves viewerToken",
          "event": [{
