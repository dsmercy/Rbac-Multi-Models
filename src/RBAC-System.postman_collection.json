    {
      "name": "5. Delegations",
      "description": "Only POST (create) and DELETE (revoke) are implemented. No GET endpoint exists.\n\nDelegator (delegator@acme.test) has content-editor role ONLY in the alpha scope (scopeId_alpha). Delegation must use scopeId_alpha and a permission the content-editor role holds.",
      "item": [

        {
          "name": "Create Delegation (as delegator)",
          "description": "Uses {{delegatorToken}}. Delegates 'roles:read' from delegator → delegatee at alpha scope. The delegator holds this permission via content-editor role at alpha scope.",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.expect(pm.response.code).to.equal(201));",
                "if (pm.response.code !== 201) return;",
                "const id = pm.response.json().id;",
                "pm.collectionVariables.set('delegationId', id);",
                "pm.test('delegationId saved: ' + id, () => pm.expect(id).to.be.a('string'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{delegatorToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
