{
  "uid": "rbac-overview",
  "title": "RBAC System — Permission Engine",
  "tags": ["rbac", "permissions"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Eval Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(rate(rbac_eval_total[1m]))", "legendFormat": "req/s" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } } },
      "targets": [{
        "expr": "sum(rate(rbac_eval_total{cache_hit=\"true\"}[5m])) / sum(rate(rbac_eval_total[5m]))",
        "legendFormat": "cache hit %"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Denial Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.10 }] } } },
      "targets": [{
        "expr": "sum(rate(rbac_eval_total{result=\"denied\"}[5m])) / sum(rate(rbac_eval_total[5m]))",
        "legendFormat": "denial %"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Delegations",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "targets": [{ "expr": "sum(rbac_active_delegations)", "legendFormat": "delegations" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Policy Eval Errors",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "targets": [{ "expr": "sum(increase(rbac_policy_eval_errors_total[5m]))", "legendFormat": "errors" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Eval Throughput — Granted vs Denied",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(rbac_eval_total{result=\"granted\"}[1m]))", "legendFormat": "granted" },
        { "expr": "sum(rate(rbac_eval_total{result=\"denied\"}[1m]))",  "legendFormat": "denied" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Eval Latency — P50 / P95 / P99 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(rbac_eval_duration_ms_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(rbac_eval_duration_ms_bucket[5m])) by (le))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(rbac_eval_duration_ms_bucket[5m])) by (le))", "legendFormat": "P99" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cache Evictions by Key Type",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 1 } } },
      "targets": [{
        "expr": "sum by (key_type) (rate(rbac_cache_evictions_total[5m]))",
        "legendFormat": "{{key_type}}"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Eval Throughput by Tenant",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [{
        "expr": "sum by (tenant_id) (rate(rbac_eval_total[1m]))",
        "legendFormat": "{{tenant_id}}"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Cache Hit Rate over Time",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [{
        "expr": "sum(rate(rbac_eval_total{cache_hit=\"true\"}[5m])) / sum(rate(rbac_eval_total[5m]))",
        "legendFormat": "hit rate"
      }]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Active Delegations by Tenant",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "expr": "sum by (tenant_id) (rbac_active_delegations)",
        "legendFormat": "{{tenant_id}}"
      }]
    }
  ]
}
