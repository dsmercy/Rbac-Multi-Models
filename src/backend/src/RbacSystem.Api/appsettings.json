  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "PermissionCache": {
    "FailClosed": false,
    "EvaluationTimeoutMs": 200,
    "StampedeLockMs": 2000,
    "L1CacheTtlSeconds": 5
  },
  "OpenTelemetry": {
    "ServiceName": "rbac-system",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "AllowedHosts": "*"
