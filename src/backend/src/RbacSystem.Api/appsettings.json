{
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=identity",
    "TenantManagement": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=tenant",
    "RbacCore": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=rbac",
    "PolicyEngine": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=policy",
    "Delegation": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=delegation",
    "AuditLogging": "Host=localhost;Port=5432;Database=rbac;Username=rbac_user;Password=${DB_PASSWORD};Search Path=audit",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "rbac-system",
    "Audience": "rbac-clients",
    "Secret": "${JWT_SECRET}",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
