{
  "ConnectionStrings": {
    "Identity": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=identity",
    "TenantManagement": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=tenant",
    "RbacCore": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=rbac",
    "PolicyEngine": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=policy",
    "Delegation": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=delegation",
    "AuditLogging": "Host=localhost;Port=5432;Database=rbac_multi_model;Username=postgres;Password=root;Search Path=audit",
    "Redis": "localhost:6379,password=dev_redis_change_me,abortConnect=false,connectTimeout=5000"
  },
  "Jwt": {
    "Issuer": "rbac-system",
    "Audience": "rbac-clients",
    "SigningKey": "my__super_secret_jwt_authentication_secret",
